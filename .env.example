# YK AI · 私有部署对话工作台 — 环境变量样例
# 复制为 `.env`（仅本地 `netlify dev` 使用）；正式部署请配置在 Netlify Site Settings → Environment variables。

# ===== 必填 =====

# 用于签发 / 校验登录 JWT。请使用一段 ≥32 字符的随机字符串，不要泄露。
JWT_SECRET=please-change-me-to-a-long-random-string

# 一键签发的初始管理员账号；首次部署后即可登录并在「用户管理」中创建其他账号。
# 当 Netlify Blobs 中已存在用户时，这两项不再生效，可移除。
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=please-change-me

# 上游 OpenAI 兼容接口（如 one-api 部署）。
ONEAPI_KEY=sk-your-oneapi-key
# 可选；默认 https://one-api.ack20.eu.org/v1
# ONEAPI_BASE=https://one-api.ack20.eu.org/v1

# Tavily 搜索 API Key（启用网络搜索时必需）。
TAVILY_API_KEY=tvly-your-key

# ===== 可选 =====

# 仅开启 Jina 抓取开关时使用。若你拥有 r.jina.ai 付费配额可填入；匿名调用也可工作但限速更严。
# JINA_API_KEY=jina_your-key
